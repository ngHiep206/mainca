{
  "entities": {
    "userProfile": {
      "title": "User Profile",
      "description": "Stores basic user information and preferences.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "child": {
      "title": "Child Profile",
      "description": "Stores information about a child.",
      "type": "object",
      "properties": {
        "parentId": { "type": "string" },
        "name": { "type": "string" },
        "birthDate": { "type": "string", "format": "date-time" },
        "gender": { "type": "string" },
        "skillScores": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "milestone": {
      "title": "Milestone Log",
      "description": "Logs child's developmental milestones.",
      "type": "object",
      "properties": {
        "childId": { "type": "string" },
        "parentId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "type": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "quizResult": {
      "title": "Quiz Result",
      "description": "Stores AI analysis from developmental quiz.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "childName": { "type": "string" },
        "childMonths": { "type": "integer" },
        "analysis": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "userProfile",
      "description": "User profile document."
    },
    "/children/{childId}": {
      "schema": "child",
      "description": "Child profile documents."
    },
    "/children/{childId}/milestones/{milestoneId}": {
      "schema": "milestone",
      "description": "Developmental milestones for children."
    },
    "/quizResults/{resultId}": {
      "schema": "quizResult",
      "description": "Saved AI analysis results."
    }
  }
}
