{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information and roles",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "role"]
    },
    "ChildProfile": {
      "title": "Child Profile",
      "description": "Information about a child including age and developmental stats",
      "type": "object",
      "properties": {
        "parentId": { "type": "string" },
        "name": { "type": "string" },
        "birthDate": { "type": "string", "format": "date-time" },
        "gender": { "type": "string", "enum": ["male", "female", "other"] },
        "skillScores": {
          "type": "object",
          "properties": {
            "motorFine": { "type": "number" },
            "motorGross": { "type": "number" },
            "language": { "type": "number" },
            "logic": { "type": "number" },
            "emotional": { "type": "number" }
          }
        },
        "shareCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["parentId", "name", "birthDate"]
    },
    "Milestone": {
      "title": "Milestone Entry",
      "description": "A developmental milestone achieved by a child",
      "type": "object",
      "properties": {
        "parentId": { "type": "string" },
        "childId": { "type": "string" },
        "title": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "description": { "type": "string" },
        "type": { "type": "string", "enum": ["motor", "language", "logic", "emotional"] }
      },
      "required": ["parentId", "childId", "title", "date"]
    },
    "Toy": {
      "title": "Toy Information",
      "description": "Detailed toy metadata including scientific info and affiliate links",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "scientificExplanation": { "type": "string" },
        "playGuide": { "type": "string" },
        "ageRangeMin": { "type": "number" },
        "ageRangeMax": { "type": "number" },
        "skills": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "price": { "type": "number" },
        "affiliateLink": { "type": "string" },
        "safetyCertificates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "expertChoice": { "type": "boolean" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "description", "ageRangeMin", "ageRangeMax"]
    },
    "ConsultationRequest": {
      "title": "Consultation Request",
      "description": "Requests for 1:1 expert consultations",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "contacted", "completed"] },
        "scheduledAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "email", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Users of the platform"
    },
    "/children/{childId}": {
      "schema": "ChildProfile",
      "description": "Children profiles registered by parents"
    },
    "/children/{childId}/milestones/{milestoneId}": {
      "schema": "Milestone",
      "description": "Milestones for a specific child"
    },
    "/toys/{toyId}": {
      "schema": "Toy",
      "description": "Educational toys database"
    },
    "/consultations/{requestId}": {
      "schema": "ConsultationRequest",
      "description": "Booking requests for expert support"
    }
  }
}
